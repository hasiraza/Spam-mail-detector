```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/

# Streamlit
.streamlit/

# Environment variables
.env

# Build / Distribution
build/
dist/
*.egg-info/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# Model artifacts (optional: remove if you want to version them)


# Testing / coverage
.coverage
htmlcov/
.pytest_cache/
```
